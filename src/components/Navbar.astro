<nav class="navbar" role="navigation" aria-label="メインナビゲーション">
  <a href="/stocks" class="navbar-brand">Slide Stock</a>
  <div class="navbar-right">
    <span id="user-name" class="navbar-user"></span>
    <button id="logout-btn" type="button" class="btn-logout">ログアウト</button>
  </div>
</nav>

<script>
  // ユーザー名を取得して表示
  fetch('/api/me')
    .then((res) => {
      if (!res.ok) return null;
      return res.json();
    })
    .then((user: { name?: string } | null) => {
      if (user?.name) {
        const el = document.getElementById('user-name');
        if (el) el.textContent = user.name;
      }
    })
    .catch(() => {
      // ユーザー名取得失敗は無視（ナビバー表示に影響しない）
    });

  // Toast 表示ヘルパー（ui-spec.md §4.2 / T-K）
  // 単一の #toast 要素を再利用。連続表示時は前回タイマーをクリアして上書きする。
  let toastTimer: number | undefined;
  function showToast(message: string, kind: 'success' | 'error' = 'error', durationMs = 4000) {
    const el = document.getElementById('toast');
    if (!el) return;
    if (toastTimer !== undefined) {
      clearTimeout(toastTimer);
    }
    el.textContent = message;
    el.className = `toast toast-${kind}`;
    el.hidden = false;
    toastTimer = window.setTimeout(() => {
      el.hidden = true;
      el.textContent = '';
    }, durationMs);
  }

  // ログアウト処理。失敗時は alert ではなく toast で表示し、サーバー側 Cookie 削除
  // が成功しなくてもクライアント側はログインページに遷移できる選択肢を残す。
  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    try {
      const res = await fetch('/api/auth/logout', { method: 'POST' });
      if (res.ok) {
        window.location.href = '/login';
      } else {
        showToast('ログアウトに失敗しました。もう一度お試しください。', 'error');
      }
    } catch {
      showToast('サーバーに接続できません。ネットワーク接続を確認してください。', 'error');
    }
  });
</script>
