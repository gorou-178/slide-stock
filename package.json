{
  "name": "slide-stock",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:worker": "wrangler dev --local-protocol=https --https-cert-path=./localhost+2.pem --https-key-path=./localhost+2-key.pem",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler pages deploy dist/",
    "db:migrate:local": "wrangler d1 execute slide-stock-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute slide-stock-db --remote --file=migrations/0001_init.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:seed": "npx tsx scripts/seed-local.ts > /tmp/slide-stock-seed.sql && wrangler d1 execute slide-stock-db --local --file=/tmp/slide-stock-seed.sql",
    "db:reset": "wrangler d1 execute slide-stock-db --local --command='DELETE FROM memos; DELETE FROM stocks; DELETE FROM users;'"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "astro": "^5.17.1",
    "jose": "^6.1.3",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.12",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@playwright/test": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.14.4"
  }
}
